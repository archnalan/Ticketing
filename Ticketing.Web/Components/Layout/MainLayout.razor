@inherits LayoutComponentBase

<div class="ft-shell">
    <header class="ft-header">
        <div class="ft-header-inner">
            <a class="ft-brand" href="/">
                <span class="ft-brand-fre">FRE</span><span class="ft-brand-lody">LODY</span>
                <span class="ft-brand-tag">Tickets</span>
            </a>

            <div class="ft-header-right">
                @* Plain JS toggle so the button works whether or not the layout is
                   rendered interactively. ftToggleTheme is defined in App.razor. *@
                <button class="ft-icon-btn" type="button" onclick="ftToggleTheme()" aria-label="Toggle theme">
                    <i class="bi bi-moon-fill ft-icon-light" aria-hidden="true"></i>
                    <i class="bi bi-sun-fill ft-icon-dark" aria-hidden="true"></i>
                </button>
                <AuthorizeView>
                    <Authorized>
                        <span class="ft-user">@context.User.Identity?.Name</span>
                        <a class="ft-btn-ghost" href="/_auth/signout">Sign out</a>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
    </header>

    <main class="ft-body">@Body</main>
</div>
