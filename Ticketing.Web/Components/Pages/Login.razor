@page "/login"
@layout LandingLayout
@* Static SSR — the form posts to /_auth/signin which sets the cookie. *@

<PageTitle>Sign in — Frelody Tickets</PageTitle>

<div class="lg-card">

    <header class="lg-brand">
        <span class="lg-brand-mark">FT</span>
        <h1 class="lg-title">Frelody Tickets</h1>
        <p class="lg-sub">Sign in with your Ticketing admin account</p>
    </header>

    <form method="post" action="/_auth/signin" class="lg-form" autocomplete="on">

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="lg-error" role="alert">@Error</div>
        }

        @if (!string.IsNullOrEmpty(ReturnUrl))
        {
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />
        }

        <div class="lg-field">
            <label for="lg-email">Email</label>
            <input id="lg-email" name="email" type="email" required
                   class="lg-input" autocomplete="username" />
        </div>

        <div class="lg-field">
            <label for="lg-pass">Password</label>
            <input id="lg-pass" name="password" type="password" required
                   class="lg-input" autocomplete="current-password" />
        </div>

        <button class="lg-submit" type="submit">Sign in</button>
    </form>

    <footer class="lg-foot">Restricted to SuperAdmin accounts only.</footer>
</div>

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] public string? Error { get; set; }
}
